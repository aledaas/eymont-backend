APP_NAME=Eymont
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------
# MYSQL
# ------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=eymont
DB_USERNAME=eymont
DB_PASSWORD=secret

# ------------------------------------------------------------------
# MONGODB
# ------------------------------------------------------------------

MONGODB_URI=mongodb://root:secret@mongo:27017/eymont_content?authSource=admin
MONGODB_DATABASE=eymont_content

# ------------------------------------------------------------------
# SESSION / CACHE / QUEUES
# ------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------
# BROADCAST / FILESYSTEM
# ------------------------------------------------------------------

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# ------------------------------------------------------------------
# MAIL
# ------------------------------------------------------------------

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@eymont.local"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# AWS / STORAGE
# ------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------
# AI
# ------------------------------------------------------------------

EYMONT_AI_PROVIDER=openai
EYMONT_AI_MODEL=gpt-5-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://ollama:11434

# ------------------------------------------------------------------
# VITE
# ------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"
